# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Point ALL three at the Ocelot API gateway (never the raw usermanagment-api port).
# For `npm run dev`, you can use `.env.development` with empty values (= same-origin +
# Vite proxy to VITE_DEV_GATEWAY_TARGET, default http://localhost:8080).
# Docker frontend uses empty build args + nginx proxy to `api-gateway`.
VITE_AUTH_API_BASE_URL=http://localhost:8080
VITE_CORE_API_BASE_URL=http://localhost:8080
VITE_USER_API_BASE_URL=http://localhost:8080
AUTH_SERVICE_HOST_PORT=5006
COREOPERATIONS_SERVICE_HOST_PORT=5007
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_SECURITY_SUPER_ADMIN_EMAIL=haroonurrasheed1212@gmail.com
APP_SECURITY_SUPER_ADMIN_PASSWORD=admin
APP_OTP_EXPIRY_MINUTES=10
# JWT lifetimes (3 days = 259200000 ms)
JWT_ACCESS_EXPIRATION_MS=259200000
JWT_REFRESH_EXPIRATION_MS=259200000
APP_SECURITY_PASSWORD_RESET_TOKEN_MS=259200000
APP_OTP_CODE_LENGTH=6
APP_OTP_SEND_EMAIL=true

# OTP emails (auth-service) — use noreply Gmail + app password
APP_MAIL_FROM=noreply.mentorhub@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply.mentorhub@gmail.com
SMTP_PASSWORD=your-noreply-app-password
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_CONNECTION_TIMEOUT=5000
SMTP_TIMEOUT=5000
SMTP_WRITE_TIMEOUT=5000
SMTP_FROM=noreply.mentorhub@gmail.com

# Platform emails (usermanagment-api) — warnings, admin messages, contact form
PlatformEmail__Enabled=true
PlatformEmail__Host=smtp.gmail.com
PlatformEmail__Port=587
PlatformEmail__Username=contact.mentorhub@gmail.com
PlatformEmail__Password=your-contact-app-password
PlatformEmail__From=contact.mentorhub@gmail.com
PlatformEmail__FromDisplayName=MentorHub
PlatformEmail__Inbox=contact.mentorhub@gmail.com
PlatformEmail__UseStartTls=true
